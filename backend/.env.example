# Server
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
MONGODB_URI=mongodb://localhost:27017/cms-dev

# Cache
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Auth (generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=replace-with-32-char-minimum-secret
JWT_REFRESH_SECRET=replace-with-different-32-char-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# OTP providers
RESEND_API_KEY=
MSG91_API_KEY=
MSG91_SENDER_ID=

# App roles/coupons
SUPERADMIN_EMAIL=founder@simplestack.in
COUPON_CODE=SANSKARDEEP

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PLAN_ID=
RAZORPAY_WEBHOOK_SECRET=

# Media
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# Storage (optional — leave blank for local storage)
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
